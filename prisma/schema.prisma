generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  password     String
  role         Role         @default(MEMBER)
  organization Organization @relation(fields: [orgId], references: [id])
  orgId        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tasksAssigned Task[] @relation("TaskAssignee")
}

model Project {
  id           String       @id @default(uuid())
  name         String
  description  String?
  organization Organization @relation(fields: [orgId], references: [id])
  orgId        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tasks Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(TODO)

  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId String?

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
}
